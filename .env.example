# AWS S3 Configuration for file uploads
# If using MinIO locally, set AWS_S3_ENDPOINT_URL to http://minio:9000
# For production AWS S3, leave AWS_S3_ENDPOINT_URL empty and set proper AWS credentials

# AWS region (default: ap-northeast-1 for Japan)
AWS_REGION=ap-northeast-1

# AWS credentials for S3 access
# For MinIO development: minioadmin / minioadmin
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# S3 bucket name for file uploads
S3_BUCKET_NAME=redmine-uploads

# S3 endpoint URL (only needed for MinIO or S3-compatible services)
# For AWS S3: leave empty or remove this line
# For MinIO: http://minio:9000
AWS_S3_ENDPOINT_URL=http://minio:9000

# Database configuration
DATABASE_URL=postgresql://redmine:redmine_password@db:5432/redmine_db

# JWT secret for authentication (change in production)
JWT_SECRET=dev-jwt-secret-change-in-production
